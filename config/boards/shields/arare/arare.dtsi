/*
 * arare keyboard - shared hardware definition
 *
 * Left  half: 6 cols × 4 rows = 24 positions, 21 keys (row3: COL0-2 only)
 * Right half: 5 cols × 4 rows = 20 positions, 20 keys (col-offset=6)
 * Total: 41 keys
 *
 * GPIO pin mapping (SuperMini NRF52840):
 *   ROW0-3:  P0.02, P0.03, P0.04, P0.05  (both halves)
 *   L COL0-5: P0.28, P0.29, P0.30, P0.31, P1.00, P1.02
 *   R COL0-4: P0.28, P0.29, P0.30, P0.31, P1.00
 *   ENC A/B:  P0.09, P0.10  (left)
 *   ENC SW:   P0.11         (left, optional key)
 *   L TP I2C: SDA=P0.12 SCL=P0.13 INT=P0.14 RST=P0.15  (IQS5xx)
 *   R TP I2C: SDA=P0.12 SCL=P0.13 INT=P0.14 RST=P0.15  (IQS5xx)
 *   PMW3610:  SCK=P0.24 SDIO=P0.20 NCS=P0.17 MOT=P0.16 (right)
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <11>;
        rows = <4>;
        /*
         * Layout (L=left, R=right):
         * Row 0: L0  L1  L2  L3  L4  L5  | R0  R1  R2  R3  R4
         * Row 1: L0  L1  L2  L3  L4  L5  | R0  R1  R2  R3  R4
         * Row 2: L0  L1  L2  L3  L4  L5  | R0  R1  R2  R3  R4
         * Row 3: L0  L1  L2              | R0  R1  R2  R3  R4
         */
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)    RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)    RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)    RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
            RC(3,0) RC(3,1) RC(3,2)                             RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "row2col";
    };

    left_encoder: encoder_left {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 9  (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <80>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder>;
        triggers-per-rotation = <20>;
    };
};
